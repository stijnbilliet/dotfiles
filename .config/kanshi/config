# Global scope: Monitor definition
output "GIGA-BYTE TECHNOLOGY CO., LTD. M27Q 20480B002546" {
    mode 2560x1440@169.831Hz
    adaptive_sync on
    scale 1
    alias $MAIN_MONITOR
}

output "TYT HDMI HDMI" {
    mode 2048x1536@60.367Hz
    transform 90
    scale 1.5
    alias $AUX_MONITOR
}

output eDP-1 {
    mode 1920x1080@60Hz
    alias $INT_MONITOR
}

# Profile scope: Monitor configuration definition
profile desktop_single {
	output $MAIN_MONITOR enable
}

profile desktop_multi {
	output $MAIN_MONITOR enable
    output $AUX_MONITOR position 768,1440 enable
    exec swaymsg focus output $MAIN_MONITOR
}

profile laptop_single {
	output $INT_MONITOR enable
}

profile laptop_multi {
	output $MAIN_MONITOR enable
	output $INT_MONITOR enable
    exec swaymsg focus output $MAIN_MONITOR
}
